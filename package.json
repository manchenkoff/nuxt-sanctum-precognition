{
  "name": "nuxt-sanctum-precognition",
  "version": "0.0.16",
  "author": {
    "name": "Artem Manchenkov",
    "email": "artem@manchenkoff.me",
    "url": "https://github.com/manchenkoff"
  },
  "description": "Nuxt module for Laravel Precognition integration",
  "homepage": "https://precognition.manchenkoff.me",
  "repository": "manchenkoff/nuxt-sanctum-precognition",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "rc": "pnpm pack --pack-destination dist",
    "dev": "npm run dev:prepare && nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit",
    "validate": "npm run lint && npm run test:types && npm run test",
    "upgrade": "pnpm self-update && npx nuxt upgrade --dedupe && pnpm up && pnpm dev:prepare && pnpm validate"
  },
  "dependencies": {
    "defu": "^6.1.7",
    "lodash-es": "^4.18.1",
    "nuxt-auth-sanctum": "^3.0.0",
    "object-form-encoder": "^0.0.6",
    "ofetch": "^1.5.1"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/kit": "^4.4.4",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.4",
    "@nuxt/test-utils": "^4.0.3",
    "@nuxt/ui": "^4.7.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.2",
    "@vue/test-utils": "^2.4.10",
    "changelogen": "^0.6.2",
    "eslint": "^10.3.0",
    "happy-dom": "^20.9.0",
    "nuxt": "^4.4.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6",
    "vue": "^3.5.34",
    "vue-tsc": "^3.2.8"
  },
  "packageManager": "pnpm@11.1.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@tailwindcss/oxide",
      "esbuild",
      "unrs-resolver",
      "vue-demi"
    ]
  }
}
